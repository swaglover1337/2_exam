<Page x:Class="_2_exam.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_2_exam"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Авторизация"
      Background="White" MaxHeight="500" MaxWidth="800">

    <Grid>

        <StackPanel Width="250" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Авторизация" FontSize="20" HorizontalAlignment="Center" Margin="20" FontWeight="Bold"/>

            <TextBlock Text="Логин:" Margin="5"/>
            <TextBox Name="LoginTextBox" Padding="5"/>

            <TextBlock Text="Пароль:" Margin="5"/>
            <PasswordBox Name="PasswordTextBox" Padding="5"/>

            <Button Content="Войти" Name="Login" Click="Login_Click" Margin="10" Padding="8" />
            <TextBlock Name="ErrorTextBlock" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap"/>

            </StackPanel>
            
    </Grid>
</Page>
